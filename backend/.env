DJANGO_SECRET_KEY=django-insecure-jade-monitor-prod-2024-change-me-in-production
DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_NAME=jade_monitor

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here

DIFFUSION_ALERT_THRESHOLD_MM=2.0
ANOMALY_SCORE_THRESHOLD=0.7

5G_BAND=n78
5G_PEAK_THROUGHPUT_GBPS=1.0
5G_SUSTAINED_THROUGHPUT_GBPS=0.8
5G_LATENCY_MS=10
5G_PACKET_LOSS_RATE=0.001

ISOLATION_FOREST_N_ESTIMATORS=50
ISOLATION_FOREST_MAX_SAMPLES=256
ISOLATION_FOREST_CONTAMINATION=0.1
ISOLATION_FOREST_MAX_BUFFER=10000

WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PONG_TIMEOUT=10
WEBSOCKET_MAX_PENDING_ALERTS=500
WEBSOCKET_PENDING_TTL=3600

SIMULATOR_ARTIFACT_COUNT=200
SIMULATOR_INTERVAL=30
